# Supabase project URL (from Project Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (from Project Settings > API)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# API base URL — leave empty in development (Vite proxy handles it)
# Set to your deployed server URL in production (e.g. https://api.example.com)
VITE_API_URL=
